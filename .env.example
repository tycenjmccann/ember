# Cloud Code — environment template. Copy to .env.local and fill in.

# AWS region the runtime + stores live in.
AWS_REGION="us-east-1"

# AgentCore coding runtime ARN (runs Claude Code / Codex per session).
CODING_AGENT_RUNTIME_ARN="arn:aws:bedrock-agentcore:us-east-1:ACCOUNT_ID:runtime/your-coding-runtime-id"

# DynamoDB table holding session rows + config-bundle metadata.
CLOUD_CODE_TABLE="agentcore-hub-cloud-code-sessions"

# S3 bucket for ported transcripts, checkpoints, and CLI config bundles.
ARTIFACT_BUCKET="agentcore-hub-artifacts-ACCOUNT_ID-us-east-1"

# Public origin used to build "port to cloud" deep links (optional locally).
# DEPLOYMENT_URL="https://your-deployment.example.com"
